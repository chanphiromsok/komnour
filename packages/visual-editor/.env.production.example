# Copy this file to .env.production (git-ignored) and point it at the real,
# deployed @komnour/server instance before running `pnpm build`. The GitHub
# Pages build is static — it cannot proxy /api anywhere, so this URL is baked
# into the JS bundle at build time and used for every export/preview request.
VITE_API_BASE_URL=https://api.example.com/api
